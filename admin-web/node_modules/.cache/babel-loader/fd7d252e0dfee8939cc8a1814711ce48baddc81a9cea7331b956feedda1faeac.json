{"ast":null,"code":"import { mapGetters } from 'vuex';\nimport { logout } from '@/api/admin/auth';\nexport default {\n  name: 'Layout',\n  computed: {\n    ...mapGetters(['sidebar', 'username']),\n    routes() {\n      return this.$router.options.routes;\n    },\n    activeMenu() {\n      const route = this.$route;\n      const {\n        meta,\n        path\n      } = route;\n      if (meta.activeMenu) {\n        return meta.activeMenu;\n      }\n      return path;\n    },\n    isCollapse() {\n      return !this.sidebar.opened;\n    }\n  },\n  methods: {\n    toggleSideBar() {\n      this.$store.dispatch('toggleSideBar');\n    },\n    handleCommand(command) {\n      if (command === 'logout') {\n        logout().then(() => {\n          this.$store.dispatch('logout');\n          this.$router.push('/login');\n        });\n      }\n    }\n  }\n};","map":{"version":3,"names":["mapGetters","logout","name","computed","routes","$router","options","activeMenu","route","$route","meta","path","isCollapse","sidebar","opened","methods","toggleSideBar","$store","dispatch","handleCommand","command","then","push"],"sources":["src/layout/index.vue"],"sourcesContent":["<template>\n  <div class=\"app-wrapper\">\n    <div class=\"sidebar-container\">\n      <el-menu\n        :default-active=\"activeMenu\"\n        :collapse=\"isCollapse\"\n        background-color=\"#304156\"\n        text-color=\"#bfcbd9\"\n        active-text-color=\"#409EFF\"\n        mode=\"vertical\"\n      >\n        <div class=\"logo\">\n          <h1>冷链物流</h1>\n        </div>\n        <sidebar-item v-for=\"route in routes\" :key=\"route.path\" :item=\"route\" :base-path=\"route.path\" />\n      </el-menu>\n    </div>\n\n    <div class=\"main-container\">\n      <div class=\"navbar\">\n        <hamburger :is-active=\"sidebar.opened\" class=\"hamburger-container\" @toggleClick=\"toggleSideBar\" />\n        <breadcrumb class=\"breadcrumb-container\" />\n        <div class=\"right-menu\">\n          <el-dropdown @command=\"handleCommand\">\n            <span class=\"el-dropdown-link\">\n              {{ username }}<i class=\"el-icon-arrow-down el-icon--right\"></i>\n            </span>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item command=\"logout\">退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </div>\n      </div>\n\n      <app-main />\n    </div>\n  </div>\n</template>\n\n<script>\nimport { mapGetters } from 'vuex'\nimport { logout } from '@/api/admin/auth'\n\nexport default {\n  name: 'Layout',\n  computed: {\n    ...mapGetters([\n      'sidebar',\n      'username'\n    ]),\n    routes() {\n      return this.$router.options.routes\n    },\n    activeMenu() {\n      const route = this.$route\n      const { meta, path } = route\n      if (meta.activeMenu) {\n        return meta.activeMenu\n      }\n      return path\n    },\n    isCollapse() {\n      return !this.sidebar.opened\n    }\n  },\n  methods: {\n    toggleSideBar() {\n      this.$store.dispatch('toggleSideBar')\n    },\n    handleCommand(command) {\n      if (command === 'logout') {\n        logout().then(() => {\n          this.$store.dispatch('logout')\n          this.$router.push('/login')\n        })\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.app-wrapper {\n  display: flex;\n  height: 100vh;\n\n  .sidebar-container {\n    width: 200px;\n    background-color: #304156;\n    height: 100vh;\n    overflow-y: auto;\n\n    .logo {\n      height: 60px;\n      line-height: 60px;\n      text-align: center;\n      background: #2b3a4a;\n\n      h1 {\n        color: #fff;\n        font-size: 20px;\n        margin: 0;\n      }\n    }\n\n    :deep(.el-menu) {\n      border: none;\n      height: calc(100vh - 60px);\n    }\n  }\n\n  .main-container {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n\n    .navbar {\n      height: 60px;\n      display: flex;\n      align-items: center;\n      background: #fff;\n      box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\n      padding: 0 20px;\n\n      .hamburger-container {\n        line-height: 60px;\n      }\n\n      .breadcrumb-container {\n        flex: 1;\n        margin-left: 20px;\n      }\n\n      .right-menu {\n        .el-dropdown-link {\n          cursor: pointer;\n          color: #333;\n        }\n      }\n    }\n  }\n}\n</style>\n"],"mappings":"AAwCA,SAAAA,UAAA;AACA,SAAAC,MAAA;AAEA;EACAC,IAAA;EACAC,QAAA;IACA,GAAAH,UAAA,EACA,WACA,WACA;IACAI,OAAA;MACA,YAAAC,OAAA,CAAAC,OAAA,CAAAF,MAAA;IACA;IACAG,WAAA;MACA,MAAAC,KAAA,QAAAC,MAAA;MACA;QAAAC,IAAA;QAAAC;MAAA,IAAAH,KAAA;MACA,IAAAE,IAAA,CAAAH,UAAA;QACA,OAAAG,IAAA,CAAAH,UAAA;MACA;MACA,OAAAI,IAAA;IACA;IACAC,WAAA;MACA,aAAAC,OAAA,CAAAC,MAAA;IACA;EACA;EACAC,OAAA;IACAC,cAAA;MACA,KAAAC,MAAA,CAAAC,QAAA;IACA;IACAC,cAAAC,OAAA;MACA,IAAAA,OAAA;QACAnB,MAAA,GAAAoB,IAAA;UACA,KAAAJ,MAAA,CAAAC,QAAA;UACA,KAAAb,OAAA,CAAAiB,IAAA;QACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}