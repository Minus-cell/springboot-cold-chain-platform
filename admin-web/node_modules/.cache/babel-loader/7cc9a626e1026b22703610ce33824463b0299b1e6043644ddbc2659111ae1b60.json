{"ast":null,"code":"import { getRoleList, addRole, updateRole, deleteRole } from '@/api/admin/role';\nexport default {\n  name: 'SystemRole',\n  data() {\n    return {\n      loading: false,\n      submitLoading: false,\n      roleList: [],\n      dialogVisible: false,\n      dialogTitle: '新增角色',\n      roleForm: {\n        id: null,\n        roleName: '',\n        roleCode: '',\n        description: '',\n        status: 1\n      },\n      roleRules: {\n        roleName: [{\n          required: true,\n          message: '请输入角色名称',\n          trigger: 'blur'\n        }],\n        roleCode: [{\n          required: true,\n          message: '请输入角色编码',\n          trigger: 'blur'\n        }, {\n          pattern: /^ROLE_\\w+$/,\n          message: '角色编码必须以ROLE_开头',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.fetchRoleList();\n  },\n  methods: {\n    fetchRoleList() {\n      this.loading = true;\n      getRoleList().then(res => {\n        this.roleList = res.data || [];\n      }).catch(() => {\n        this.roleList = [];\n      }).finally(() => {\n        this.loading = false;\n      });\n    },\n    handleAdd() {\n      this.dialogTitle = '新增角色';\n      this.roleForm = {\n        id: null,\n        roleName: '',\n        roleCode: '',\n        description: '',\n        status: 1\n      };\n      this.dialogVisible = true;\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑角色';\n      this.roleForm = {\n        id: row.id,\n        roleName: row.roleName,\n        roleCode: row.roleCode,\n        description: row.description,\n        status: row.status\n      };\n      this.dialogVisible = true;\n    },\n    handleDelete(row) {\n      this.$confirm(`确定要删除角色 \"${row.roleName}\" 吗？`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        deleteRole(row.id).then(() => {\n          this.$message.success('删除成功');\n          this.fetchRoleList();\n        });\n      }).catch(() => {});\n    },\n    handleSubmit() {\n      this.$refs.roleForm.validate(valid => {\n        if (valid) {\n          this.submitLoading = true;\n          const action = this.roleForm.id ? updateRole : addRole;\n          action(this.roleForm).then(() => {\n            this.$message.success(this.roleForm.id ? '修改成功' : '新增成功');\n            this.dialogVisible = false;\n            this.fetchRoleList();\n          }).finally(() => {\n            this.submitLoading = false;\n          });\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["getRoleList","addRole","updateRole","deleteRole","name","data","loading","submitLoading","roleList","dialogVisible","dialogTitle","roleForm","id","roleName","roleCode","description","status","roleRules","required","message","trigger","pattern","created","fetchRoleList","methods","then","res","catch","finally","handleAdd","handleEdit","row","handleDelete","$confirm","confirmButtonText","cancelButtonText","type","$message","success","handleSubmit","$refs","validate","valid","action"],"sources":["src/views/system/role.vue"],"sourcesContent":["<template>\n  <div class=\"role-manage\">\n    <el-card>\n      <div slot=\"header\" class=\"clearfix\">\n        <span>角色管理</span>\n        <el-button style=\"float: right;\" type=\"primary\" icon=\"el-icon-plus\" size=\"small\" @click=\"handleAdd\">\n          新增角色\n        </el-button>\n      </div>\n\n      <el-table :data=\"roleList\" v-loading=\"loading\" stripe>\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"roleName\" label=\"角色名称\" width=\"150\"></el-table-column>\n        <el-table-column prop=\"roleCode\" label=\"角色编码\" width=\"150\"></el-table-column>\n        <el-table-column prop=\"description\" label=\"描述\" min-width=\"200\"></el-table-column>\n        <el-table-column label=\"状态\" width=\"80\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"scope.row.status === 1 ? 'success' : 'danger'\" size=\"small\">\n              {{ scope.row.status === 1 ? '启用' : '禁用' }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"180\"></el-table-column>\n        <el-table-column label=\"操作\" width=\"180\" fixed=\"right\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"text\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\n            <el-button type=\"text\" size=\"small\" @click=\"handleDelete(scope.row)\" style=\"color: #F56C6C;\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"500px\" :close-on-click-modal=\"false\">\n      <el-form :model=\"roleForm\" :rules=\"roleRules\" ref=\"roleForm\" label-width=\"100px\">\n        <el-form-item label=\"角色名称\" prop=\"roleName\">\n          <el-input v-model=\"roleForm.roleName\" placeholder=\"请输入角色名称\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"角色编码\" prop=\"roleCode\">\n          <el-input v-model=\"roleForm.roleCode\" placeholder=\"请输入角色编码（如：ROLE_ADMIN）\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"描述\" prop=\"description\">\n          <el-input v-model=\"roleForm.description\" type=\"textarea\" :rows=\"3\" placeholder=\"请输入描述\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"状态\" prop=\"status\">\n          <el-radio-group v-model=\"roleForm.status\">\n            <el-radio :label=\"1\">启用</el-radio>\n            <el-radio :label=\"0\">禁用</el-radio>\n          </el-radio-group>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\" :loading=\"submitLoading\">确 定</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { getRoleList, addRole, updateRole, deleteRole } from '@/api/admin/role'\n\nexport default {\n  name: 'SystemRole',\n  data() {\n    return {\n      loading: false,\n      submitLoading: false,\n      roleList: [],\n      dialogVisible: false,\n      dialogTitle: '新增角色',\n      roleForm: {\n        id: null,\n        roleName: '',\n        roleCode: '',\n        description: '',\n        status: 1\n      },\n      roleRules: {\n        roleName: [{ required: true, message: '请输入角色名称', trigger: 'blur' }],\n        roleCode: [\n          { required: true, message: '请输入角色编码', trigger: 'blur' },\n          { pattern: /^ROLE_\\w+$/, message: '角色编码必须以ROLE_开头', trigger: 'blur' }\n        ]\n      }\n    }\n  },\n  created() {\n    this.fetchRoleList()\n  },\n  methods: {\n    fetchRoleList() {\n      this.loading = true\n      getRoleList().then(res => {\n        this.roleList = res.data || []\n      }).catch(() => {\n        this.roleList = []\n      }).finally(() => {\n        this.loading = false\n      })\n    },\n    handleAdd() {\n      this.dialogTitle = '新增角色'\n      this.roleForm = {\n        id: null,\n        roleName: '',\n        roleCode: '',\n        description: '',\n        status: 1\n      }\n      this.dialogVisible = true\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑角色'\n      this.roleForm = {\n        id: row.id,\n        roleName: row.roleName,\n        roleCode: row.roleCode,\n        description: row.description,\n        status: row.status\n      }\n      this.dialogVisible = true\n    },\n    handleDelete(row) {\n      this.$confirm(`确定要删除角色 \"${row.roleName}\" 吗？`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        deleteRole(row.id).then(() => {\n          this.$message.success('删除成功')\n          this.fetchRoleList()\n        })\n      }).catch(() => {})\n    },\n    handleSubmit() {\n      this.$refs.roleForm.validate(valid => {\n        if (valid) {\n          this.submitLoading = true\n          const action = this.roleForm.id ? updateRole : addRole\n          action(this.roleForm).then(() => {\n            this.$message.success(this.roleForm.id ? '修改成功' : '新增成功')\n            this.dialogVisible = false\n            this.fetchRoleList()\n          }).finally(() => {\n            this.submitLoading = false\n          })\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.role-manage {\n  padding: 20px;\n}\n</style>"],"mappings":"AA2DA,SAAAA,WAAA,EAAAC,OAAA,EAAAC,UAAA,EAAAC,UAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,aAAA;MACAC,QAAA;MACAC,aAAA;MACAC,WAAA;MACAC,QAAA;QACAC,EAAA;QACAC,QAAA;QACAC,QAAA;QACAC,WAAA;QACAC,MAAA;MACA;MACAC,SAAA;QACAJ,QAAA;UAAAK,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAN,QAAA,GACA;UAAAI,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,GACA;UAAAC,OAAA;UAAAF,OAAA;UAAAC,OAAA;QAAA;MAEA;IACA;EACA;EACAE,QAAA;IACA,KAAAC,aAAA;EACA;EACAC,OAAA;IACAD,cAAA;MACA,KAAAjB,OAAA;MACAN,WAAA,GAAAyB,IAAA,CAAAC,GAAA;QACA,KAAAlB,QAAA,GAAAkB,GAAA,CAAArB,IAAA;MACA,GAAAsB,KAAA;QACA,KAAAnB,QAAA;MACA,GAAAoB,OAAA;QACA,KAAAtB,OAAA;MACA;IACA;IACAuB,UAAA;MACA,KAAAnB,WAAA;MACA,KAAAC,QAAA;QACAC,EAAA;QACAC,QAAA;QACAC,QAAA;QACAC,WAAA;QACAC,MAAA;MACA;MACA,KAAAP,aAAA;IACA;IACAqB,WAAAC,GAAA;MACA,KAAArB,WAAA;MACA,KAAAC,QAAA;QACAC,EAAA,EAAAmB,GAAA,CAAAnB,EAAA;QACAC,QAAA,EAAAkB,GAAA,CAAAlB,QAAA;QACAC,QAAA,EAAAiB,GAAA,CAAAjB,QAAA;QACAC,WAAA,EAAAgB,GAAA,CAAAhB,WAAA;QACAC,MAAA,EAAAe,GAAA,CAAAf;MACA;MACA,KAAAP,aAAA;IACA;IACAuB,aAAAD,GAAA;MACA,KAAAE,QAAA,aAAAF,GAAA,CAAAlB,QAAA;QACAqB,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GAAAX,IAAA;QACAtB,UAAA,CAAA4B,GAAA,CAAAnB,EAAA,EAAAa,IAAA;UACA,KAAAY,QAAA,CAAAC,OAAA;UACA,KAAAf,aAAA;QACA;MACA,GAAAI,KAAA;IACA;IACAY,aAAA;MACA,KAAAC,KAAA,CAAA7B,QAAA,CAAA8B,QAAA,CAAAC,KAAA;QACA,IAAAA,KAAA;UACA,KAAAnC,aAAA;UACA,MAAAoC,MAAA,QAAAhC,QAAA,CAAAC,EAAA,GAAAV,UAAA,GAAAD,OAAA;UACA0C,MAAA,MAAAhC,QAAA,EAAAc,IAAA;YACA,KAAAY,QAAA,C