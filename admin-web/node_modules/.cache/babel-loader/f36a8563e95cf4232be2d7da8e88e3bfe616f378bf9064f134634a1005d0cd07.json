{"ast":null,"code":"import { getUserList, addUser, updateUser, deleteUser } from '@/api/admin/user';\nexport default {\n  name: 'SystemUser',\n  data() {\n    return {\n      loading: false,\n      submitLoading: false,\n      userList: [],\n      pagination: {\n        page: 1,\n        size: 10,\n        total: 0\n      },\n      dialogVisible: false,\n      dialogTitle: '新增用户',\n      userForm: {\n        id: null,\n        username: '',\n        realName: '',\n        phone: '',\n        email: '',\n        password: '',\n        status: 1\n      },\n      userRules: {\n        username: [{\n          required: true,\n          message: '请输入用户名',\n          trigger: 'blur'\n        }],\n        realName: [{\n          required: true,\n          message: '请输入真实姓名',\n          trigger: 'blur'\n        }],\n        phone: [{\n          pattern: /^1[3-9]\\d{9}$/,\n          message: '请输入正确的手机号',\n          trigger: 'blur'\n        }],\n        email: [{\n          type: 'email',\n          message: '请输入正确的邮箱',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.fetchUserList();\n  },\n  methods: {\n    fetchUserList() {\n      this.loading = true;\n      getUserList({\n        page: this.pagination.page,\n        size: this.pagination.size\n      }).then(res => {\n        this.userList = res.data.records || res.data || [];\n        this.pagination.total = res.data.total || this.userList.length;\n      }).catch(() => {\n        this.userList = [];\n      }).finally(() => {\n        this.loading = false;\n      });\n    },\n    handleAdd() {\n      this.dialogTitle = '新增用户';\n      this.userForm = {\n        id: null,\n        username: '',\n        realName: '',\n        phone: '',\n        email: '',\n        password: '',\n        status: 1\n      };\n      this.dialogVisible = true;\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑用户';\n      this.userForm = {\n        id: row.id,\n        username: row.username,\n        realName: row.realName,\n        phone: row.phone,\n        email: row.email,\n        status: row.status\n      };\n      this.dialogVisible = true;\n    },\n    handleDelete(row) {\n      this.$confirm(`确定要删除用户 \"${row.username}\" 吗？`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        deleteUser(row.id).then(() => {\n          this.$message.success('删除成功');\n          this.fetchUserList();\n        });\n      }).catch(() => {});\n    },\n    handleSubmit() {\n      this.$refs.userForm.validate(valid => {\n        if (valid) {\n          this.submitLoading = true;\n          const action = this.userForm.id ? updateUser : addUser;\n          action(this.userForm).then(() => {\n            this.$message.success(this.userForm.id ? '修改成功' : '新增成功');\n            this.dialogVisible = false;\n            this.fetchUserList();\n          }).finally(() => {\n            this.submitLoading = false;\n          });\n        }\n      });\n    },\n    handleSizeChange(val) {\n      this.pagination.size = val;\n      this.fetchUserList();\n    },\n    handleCurrentChange(val) {\n      this.pagination.page = val;\n      this.fetchUserList();\n    }\n  }\n};","map":{"version":3,"names":["getUserList","addUser","updateUser","deleteUser","name","data","loading","submitLoading","userList","pagination","page","size","total","dialogVisible","dialogTitle","userForm","id","username","realName","phone","email","password","status","userRules","required","message","trigger","pattern","type","created","fetchUserList","methods","then","res","records","length","catch","finally","handleAdd","handleEdit","row","handleDelete","$confirm","confirmButtonText","cancelButtonText","$message","success","handleSubmit","$refs","validate","valid","action","handleSizeChange","val","handleCurrentChange"],"sources":["src/views/system/user.vue"],"sourcesContent":["<template>\n  <div class=\"user-manage\">\n    <el-card>\n      <div slot=\"header\" class=\"clearfix\">\n        <span>用户管理</span>\n        <el-button style=\"float: right;\" type=\"primary\" icon=\"el-icon-plus\" size=\"small\" @click=\"handleAdd\">\n          新增用户\n        </el-button>\n      </div>\n\n      <el-table :data=\"userList\" v-loading=\"loading\" stripe>\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"username\" label=\"用户名\" width=\"150\"></el-table-column>\n        <el-table-column prop=\"realName\" label=\"真实姓名\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"phone\" label=\"手机号\" width=\"130\"></el-table-column>\n        <el-table-column prop=\"email\" label=\"邮箱\" min-width=\"180\"></el-table-column>\n        <el-table-column label=\"状态\" width=\"80\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"scope.row.status === 1 ? 'success' : 'danger'\" size=\"small\">\n              {{ scope.row.status === 1 ? '启用' : '禁用' }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"180\"></el-table-column>\n        <el-table-column label=\"操作\" width=\"180\" fixed=\"right\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"text\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\n            <el-button type=\"text\" size=\"small\" @click=\"handleDelete(scope.row)\" style=\"color: #F56C6C;\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <el-pagination\n        @size-change=\"handleSizeChange\"\n        @current-change=\"handleCurrentChange\"\n        :current-page=\"pagination.page\"\n        :page-sizes=\"[10, 20, 50, 100]\"\n        :page-size=\"pagination.size\"\n        layout=\"total, sizes, prev, pager, next, jumper\"\n        :total=\"pagination.total\"\n        style=\"margin-top: 20px; text-align: right;\">\n      </el-pagination>\n    </el-card>\n\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"500px\" :close-on-click-modal=\"false\">\n      <el-form :model=\"userForm\" :rules=\"userRules\" ref=\"userForm\" label-width=\"100px\">\n        <el-form-item label=\"用户名\" prop=\"username\">\n          <el-input v-model=\"userForm.username\" :disabled=\"!!userForm.id\" placeholder=\"请输入用户名\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"真实姓名\" prop=\"realName\">\n          <el-input v-model=\"userForm.realName\" placeholder=\"请输入真实姓名\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"手机号\" prop=\"phone\">\n          <el-input v-model=\"userForm.phone\" placeholder=\"请输入手机号\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"邮箱\" prop=\"email\">\n          <el-input v-model=\"userForm.email\" placeholder=\"请输入邮箱\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"密码\" prop=\"password\" v-if=\"!userForm.id\">\n          <el-input v-model=\"userForm.password\" type=\"password\" placeholder=\"请输入密码（默认admin123）\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"状态\" prop=\"status\">\n          <el-radio-group v-model=\"userForm.status\">\n            <el-radio :label=\"1\">启用</el-radio>\n            <el-radio :label=\"0\">禁用</el-radio>\n          </el-radio-group>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\" :loading=\"submitLoading\">确 定</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { getUserList, addUser, updateUser, deleteUser } from '@/api/admin/user'\n\nexport default {\n  name: 'SystemUser',\n  data() {\n    return {\n      loading: false,\n      submitLoading: false,\n      userList: [],\n      pagination: {\n        page: 1,\n        size: 10,\n        total: 0\n      },\n      dialogVisible: false,\n      dialogTitle: '新增用户',\n      userForm: {\n        id: null,\n        username: '',\n        realName: '',\n        phone: '',\n        email: '',\n        password: '',\n        status: 1\n      },\n      userRules: {\n        username: [{ required: true, message: '请输入用户名', trigger: 'blur' }],\n        realName: [{ required: true, message: '请输入真实姓名', trigger: 'blur' }],\n        phone: [{ pattern: /^1[3-9]\\d{9}$/, message: '请输入正确的手机号', trigger: 'blur' }],\n        email: [{ type: 'email', message: '请输入正确的邮箱', trigger: 'blur' }]\n      }\n    }\n  },\n  created() {\n    this.fetchUserList()\n  },\n  methods: {\n    fetchUserList() {\n      this.loading = true\n      getUserList({\n        page: this.pagination.page,\n        size: this.pagination.size\n      }).then(res => {\n        this.userList = res.data.records || res.data || []\n        this.pagination.total = res.data.total || this.userList.length\n      }).catch(() => {\n        this.userList = []\n      }).finally(() => {\n        this.loading = false\n      })\n    },\n    handleAdd() {\n      this.dialogTitle = '新增用户'\n      this.userForm = {\n        id: null,\n        username: '',\n        realName: '',\n        phone: '',\n        email: '',\n        password: '',\n        status: 1\n      }\n      this.dialogVisible = true\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑用户'\n      this.userForm = {\n        id: row.id,\n        username: row.username,\n        realName: row.realName,\n        phone: row.phone,\n        email: row.email,\n        status: row.status\n      }\n      this.dialogVisible = true\n    },\n    handleDelete(row) {\n      this.$confirm(`确定要删除用户 \"${row.username}\" 吗？`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        deleteUser(row.id).then(() => {\n          this.$message.success('删除成功')\n          this.fetchUserList()\n        })\n      }).catch(() => {})\n    },\n    handleSubmit() {\n      this.$refs.userForm.validate(valid => {\n        if (valid) {\n          this.submitLoading = true\n          const action = this.userForm.id ? updateUser : addUser\n          action(this.userForm).then(() => {\n            this.$message.success(this.userForm.id ? '修改成功' : '新增成功')\n            this.dialogVisible = false\n            this.fetchUserList()\n          }).finally(() => {\n            this.submitLoading = false\n          })\n        }\n      })\n    },\n    handleSizeChange(val) {\n      this.pagination.size = val\n      this.fetchUserList()\n    },\n    handleCurrentChange(val) {\n      this.pagination.page = val\n      this.fetchUserList()\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.user-manage {\n  padding: 20px;\n}\n</style>"],"mappings":"AA6EA,SAAAA,WAAA,EAAAC,OAAA,EAAAC,UAAA,EAAAC,UAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,aAAA;MACAC,QAAA;MACAC,UAAA;QACAC,IAAA;QACAC,IAAA;QACAC,KAAA;MACA;MACAC,aAAA;MACAC,WAAA;MACAC,QAAA;QACAC,EAAA;QACAC,QAAA;QACAC,QAAA;QACAC,KAAA;QACAC,KAAA;QACAC,QAAA;QACAC,MAAA;MACA;MACAC,SAAA;QACAN,QAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAR,QAAA;UAAAM,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAP,KAAA;UAAAQ,OAAA;UAAAF,OAAA;UAAAC,OAAA;QAAA;QACAN,KAAA;UAAAQ,IAAA;UAAAH,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAG,QAAA;IACA,KAAAC,aAAA;EACA;EACAC,OAAA;IACAD,cAAA;MACA,KAAAxB,OAAA;MACAN,WAAA;QACAU,IAAA,OAAAD,UAAA,CAAAC,IAAA;QACAC,IAAA,OAAAF,UAAA,CAAAE;MACA,GAAAqB,IAAA,CAAAC,GAAA;QACA,KAAAzB,QAAA,GAAAyB,GAAA,CAAA5B,IAAA,CAAA6B,OAAA,IAAAD,GAAA,CAAA5B,IAAA;QACA,KAAAI,UAAA,CAAAG,KAAA,GAAAqB,GAAA,CAAA5B,IAAA,CAAAO,KAAA,SAAAJ,QAAA,CAAA2B,MAAA;MACA,GAAAC,KAAA;QACA,KAAA5B,QAAA;MACA,GAAA6B,OAAA;QACA,KAAA/B,OAAA;MACA;IACA;IACAgC,UAAA;MACA,KAAAxB,WAAA;MACA,KAAAC,QAAA;QACAC,EAAA;QACAC,QAAA;QACAC,QAAA;QACAC,KAAA;QACAC,KAAA;QACAC,QAAA;QACAC,MAAA;MACA;MACA,KAAAT,aAAA;IACA;IACA0B,WAAAC,GAAA;MACA,KAAA1B,WAAA;MACA,KAAAC,QAAA;QACAC,EAAA,EAAAwB,GAAA,CAAAxB,EAAA;QACAC,