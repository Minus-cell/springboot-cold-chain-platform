{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { logout } from '@/api/admin/auth';\nexport default {\n  name: 'Layout',\n  computed: {\n    activeMenu() {\n      const route = this.$route;\n      const {\n        meta,\n        path\n      } = route;\n      if (meta.activeMenu) {\n        return meta.activeMenu;\n      }\n      return path;\n    },\n    pageTitle() {\n      return this.$route.meta && this.$route.meta.title ? this.$route.meta.title : '后台管理';\n    },\n    username() {\n      return this.$store.state.userInfo && this.$store.state.userInfo.username ? this.$store.state.userInfo.username : '管理员';\n    }\n  },\n  methods: {\n    handleCommand(command) {\n      if (command === 'logout') {\n        logout().then(() => {\n          this.$store.dispatch('logout');\n          this.$router.push('/login');\n        });\n      }\n    }\n  }\n};","map":{"version":3,"names":["logout","name","computed","activeMenu","route","$route","meta","path","pageTitle","title","username","$store","state","userInfo","methods","handleCommand","command","then","dispatch","$router","push"],"sources":["src/layout/index.vue"],"sourcesContent":["<template>\n  <div class=\"app-wrapper\">\n    <div class=\"sidebar-container\">\n      <el-menu\n        :default-active=\"activeMenu\"\n        :collapse=\"isCollapse\"\n        background-color=\"#304156\"\n        text-color=\"#bfcbd9\"\n        active-text-color=\"#409EFF\"\n        mode=\"vertical\"\n      >\n        <div class=\"logo\">\n          <h1>冷链物流</h1>\n        </div>\n        <el-menu-item index=\"/dashboard\" @click=\"$router.push('/dashboard')\">\n          <i class=\"el-icon-data-line\"></i>\n          <span slot=\"title\">仪表盘</span>\n        </el-menu-item>\n        <el-menu-item index=\"/order/index\" @click=\"$router.push('/order/index')\">\n          <i class=\"el-icon-document\"></i>\n          <span slot=\"title\">运单管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/vehicle/index\" @click=\"$router.push('/vehicle/index')\">\n          <i class=\"el-icon-truck\"></i>\n          <span slot=\"title\">车辆管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/temperature/index\" @click=\"$router.push('/temperature/index')\">\n          <i class=\"el-icon-data-analysis\"></i>\n          <span slot=\"title\">温控管理</span>\n        </el-menu-item>\n        <el-submenu index=\"/system\">\n          <template slot=\"title\">\n            <i class=\"el-icon-setting\"></i>\n            <span>系统管理</span>\n          </template>\n          <el-menu-item index=\"/system/user\" @click=\"$router.push('/system/user')\">用户管理</el-menu-item>\n          <el-menu-item index=\"/system/role\" @click=\"$router.push('/system/role')\">角色管理</el-menu-item>\n        </el-submenu>\n      </el-menu>\n    </div>\n\n    <div class=\"main-container\">\n      <div class=\"navbar\">\n        <div class=\"page-title\">{{ pageTitle }}</div>\n        <div class=\"right-menu\">\n          <el-dropdown @command=\"handleCommand\">\n            <span class=\"el-dropdown-link\">\n              {{ username }}<i class=\"el-icon-arrow-down el-icon--right\"></i>\n            </span>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item command=\"logout\">退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </div>\n      </div>\n\n      <div class=\"content-container\">\n        <router-view />\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { logout } from '@/api/admin/auth'\n\nexport default {\n  name: 'Layout',\n  computed: {\n    activeMenu() {\n      const route = this.$route\n      const { meta, path } = route\n      if (meta.activeMenu) {\n        return meta.activeMenu\n      }\n      return path\n    },\n    pageTitle() {\n      return this.$route.meta && this.$route.meta.title ? this.$route.meta.title : '后台管理'\n    },\n    username() {\n      return this.$store.state.userInfo && this.$store.state.userInfo.username\n        ? this.$store.state.userInfo.username\n        : '管理员'\n    }\n  },\n  methods: {\n    handleCommand(command) {\n      if (command === 'logout') {\n        logout().then(() => {\n          this.$store.dispatch('logout')\n          this.$router.push('/login')\n        })\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.app-wrapper {\n  display: flex;\n  height: 100vh;\n\n  .sidebar-container {\n    width: 200px;\n    background-color: #304156;\n    height: 100vh;\n    overflow-y: auto;\n\n    .logo {\n      height: 60px;\n      line-height: 60px;\n      text-align: center;\n      background: #2b3a4a;\n\n      h1 {\n        color: #fff;\n        font-size: 20px;\n        margin: 0;\n      }\n    }\n\n    :deep(.el-menu) {\n      border: none;\n      height: calc(100vh - 60px);\n    }\n  }\n\n  .main-container {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n\n    .content-container {\n      flex: 1;\n      overflow: auto;\n      background: #f5f7fa;\n    }\n\n    .navbar {\n      height: 60px;\n      display: flex;\n      align-items: center;\n      background: #fff;\n      box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\n      padding: 0 20px;\n\n      .page-title {\n        flex: 1;\n        font-size: 18px;\n        font-weight: 600;\n        color: #333;\n      }\n\n      .right-menu {\n        .el-dropdown-link {\n          cursor: pointer;\n          color: #333;\n        }\n      }\n    }\n  }\n}\n</style>\n"],"mappings":";AAgEA,SAAAA,MAAA;AAEA;EACAC,IAAA;EACAC,QAAA;IACAC,WAAA;MACA,MAAAC,KAAA,QAAAC,MAAA;MACA;QAAAC,IAAA;QAAAC;MAAA,IAAAH,KAAA;MACA,IAAAE,IAAA,CAAAH,UAAA;QACA,OAAAG,IAAA,CAAAH,UAAA;MACA;MACA,OAAAI,IAAA;IACA;IACAC,UAAA;MACA,YAAAH,MAAA,CAAAC,IAAA,SAAAD,MAAA,CAAAC,IAAA,CAAAG,KAAA,QAAAJ,MAAA,CAAAC,IAAA,CAAAG,KAAA;IACA;IACAC,SAAA;MACA,YAAAC,MAAA,CAAAC,KAAA,CAAAC,QAAA,SAAAF,MAAA,CAAAC,KAAA,CAAAC,QAAA,CAAAH,QAAA,GACA,KAAAC,MAAA,CAAAC,KAAA,CAAAC,QAAA,CAAAH,QAAA