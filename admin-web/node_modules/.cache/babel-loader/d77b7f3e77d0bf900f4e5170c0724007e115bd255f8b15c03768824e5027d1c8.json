{"ast":null,"code":"import * as echarts from 'echarts';\nimport { getList, getChart, getAlarms, getLatest } from '@/api/admin/temperature';\nimport { getList as getOrderList } from '@/api/admin/order';\nexport default {\n  name: 'Temperature',\n  data() {\n    return {\n      tableData: [],\n      alarms: [],\n      orders: [],\n      selectedOrder: null,\n      chart: null,\n      pagination: {\n        current: 1,\n        size: 10,\n        total: 0\n      }\n    };\n  },\n  mounted() {\n    this.loadData();\n    this.loadOrders();\n    this.loadAlarms();\n  },\n  beforeDestroy() {\n    if (this.chart) {\n      this.chart.dispose();\n    }\n  },\n  methods: {\n    loadData() {\n      const params = {\n        current: this.pagination.current,\n        size: this.pagination.size\n      };\n      getList(params).then(response => {\n        this.tableData = response.data.records;\n        this.pagination.total = response.data.total;\n      });\n    },\n    loadOrders() {\n      getOrderList({\n        current: 1,\n        size: 100\n      }).then(response => {\n        this.orders = response.data.records;\n      });\n    },\n    loadAlarms() {\n      getAlarms().then(response => {\n        this.alarms = response.data;\n      });\n    },\n    loadChart(orderId) {\n      if (!orderId) return;\n      getChart(orderId).then(response => {\n        const data = response.data;\n        this.initChart(data.dates, data.temperatures, data.humidities);\n      });\n    },\n    initChart(dates, temperatures, humidities) {\n      if (!this.$refs.chart) return;\n      this.chart = echarts.init(this.$refs.chart);\n      const option = {\n        tooltip: {\n          trigger: 'axis'\n        },\n        legend: {\n          data: ['温度', '湿度']\n        },\n        xAxis: {\n          type: 'category',\n          data: dates\n        },\n        yAxis: [{\n          type: 'value',\n          name: '温度(℃)',\n          axisLabel: {\n            formatter: '{value} °C'\n          }\n        }, {\n          type: 'value',\n          name: '湿度(%)',\n          axisLabel: {\n            formatter: '{value} %'\n          }\n        }],\n        series: [{\n          name: '温度',\n          type: 'line',\n          data: temperatures,\n          smooth: true,\n          markLine: {\n            data: [{\n              yAxis: -18,\n              name: '下限'\n            }, {\n              yAxis: -25,\n              name: '告警'\n            }]\n          }\n        }, {\n          name: '湿度',\n          type: 'line',\n          yAxisIndex: 1,\n          data: humidities,\n          smooth: true\n        }]\n      };\n      this.chart.setOption(option);\n    },\n    handlePageChange(page) {\n      this.pagination.current = page;\n      this.loadData();\n    }\n  }\n};","map":{"version":3,"names":["echarts","getList","getChart","getAlarms","getLatest","getOrderList","name","data","tableData","alarms","orders","selectedOrder","chart","pagination","current","size","total","mounted","loadData","loadOrders","loadAlarms","beforeDestroy","dispose","methods","params","then","response","records","loadChart","orderId","initChart","dates","temperatures","humidities","$refs","init","option","tooltip","trigger","legend","xAxis","type","yAxis","axisLabel","formatter","series","smooth","markLine","yAxisIndex","setOption","handlePageChange","page"],"sources":["src/views/temperature/index.vue"],"sourcesContent":["<template>\n  <div class=\"temperature-container\">\n    <el-row :gutter=\"20\">\n      <el-col :span=\"16\">\n        <el-card>\n          <div slot=\"header\">\n            <span>温度曲线</span>\n            <el-select v-model=\"selectedOrder\" placeholder=\"请选择运单\" style=\"float: right; width: 200px;\" @change=\"loadChart\">\n              <el-option v-for=\"order in orders\" :key=\"order.id\" :label=\"order.orderNo\" :value=\"order.id\"></el-option>\n            </el-select>\n          </div>\n          <div ref=\"chart\" style=\"height: 400px;\"></div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"8\">\n        <el-card>\n          <div slot=\"header\">\n            <span>最新告警</span>\n          </div>\n          <el-table :data=\"alarms\" max-height=\"400\">\n            <el-table-column prop=\"temperature\" label=\"温度(℃)\" width=\"80\"></el-table-column>\n            <el-table-column prop=\"location\" label=\"位置\" width=\"100\"></el-table-column>\n            <el-table-column prop=\"recordTime\" label=\"时间\"></el-table-column>\n          </el-table>\n        </el-card>\n      </el-col>\n    </el-row>\n\n    <el-card style=\"margin-top: 20px;\">\n      <div slot=\"header\">\n        <span>温度记录列表</span>\n      </div>\n      <el-table :data=\"tableData\" border stripe>\n        <el-table-column prop=\"orderId\" label=\"运单ID\" width=\"100\"></el-table-column>\n        <el-table-column prop=\"vehicleId\" label=\"车辆ID\" width=\"100\"></el-table-column>\n        <el-table-column prop=\"temperature\" label=\"温度(℃)\" width=\"100\"></el-table-column>\n        <el-table-column prop=\"humidity\" label=\"湿度(%)\" width=\"100\"></el-table-column>\n        <el-table-column prop=\"location\" label=\"位置\"></el-table-column>\n        <el-table-column prop=\"recordTime\" label=\"记录时间\" width=\"180\"></el-table-column>\n      </el-table>\n\n      <el-pagination\n        @current-change=\"handlePageChange\"\n        :current-page=\"pagination.current\"\n        :page-size=\"pagination.size\"\n        :total=\"pagination.total\"\n        layout=\"total, prev, pager, next\"\n        style=\"margin-top: 20px; text-align: right;\">\n      </el-pagination>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nimport { getList, getChart, getAlarms, getLatest } from '@/api/admin/temperature'\nimport { getList as getOrderList } from '@/api/admin/order'\n\nexport default {\n  name: 'Temperature',\n  data() {\n    return {\n      tableData: [],\n      alarms: [],\n      orders: [],\n      selectedOrder: null,\n      chart: null,\n      pagination: {\n        current: 1,\n        size: 10,\n        total: 0\n      }\n    }\n  },\n  mounted() {\n    this.loadData()\n    this.loadOrders()\n    this.loadAlarms()\n  },\n  beforeDestroy() {\n    if (this.chart) {\n      this.chart.dispose()\n    }\n  },\n  methods: {\n    loadData() {\n      const params = {\n        current: this.pagination.current,\n        size: this.pagination.size\n      }\n      getList(params).then(response => {\n        this.tableData = response.data.records\n        this.pagination.total = response.data.total\n      })\n    },\n    loadOrders() {\n      getOrderList({ current: 1, size: 100 }).then(response => {\n        this.orders = response.data.records\n      })\n    },\n    loadAlarms() {\n      getAlarms().then(response => {\n        this.alarms = response.data\n      })\n    },\n    loadChart(orderId) {\n      if (!orderId) return\n\n      getChart(orderId).then(response => {\n        const data = response.data\n        this.initChart(data.dates, data.temperatures, data.humidities)\n      })\n    },\n    initChart(dates, temperatures, humidities) {\n      if (!this.$refs.chart) return\n\n      this.chart = echarts.init(this.$refs.chart)\n      const option = {\n        tooltip: {\n          trigger: 'axis'\n        },\n        legend: {\n          data: ['温度', '湿度']\n        },\n        xAxis: {\n          type: 'category',\n          data: dates\n        },\n        yAxis: [\n          {\n            type: 'value',\n            name: '温度(℃)',\n            axisLabel: {\n              formatter: '{value} °C'\n            }\n          },\n          {\n            type: 'value',\n            name: '湿度(%)',\n            axisLabel: {\n              formatter: '{value} %'\n            }\n          }\n        ],\n        series: [\n          {\n            name: '温度',\n            type: 'line',\n            data: temperatures,\n            smooth: true,\n            markLine: {\n              data: [\n                { yAxis: -18, name: '下限' },\n                { yAxis: -25, name: '告警' }\n              ]\n            }\n          },\n          {\n            name: '湿度',\n            type: 'line',\n            yAxisIndex: 1,\n            data: humidities,\n            smooth: true\n          }\n        ]\n      }\n      this.chart.setOption(option)\n    },\n    handlePageChange(page) {\n      this.pagination.current = page\n      this.loadData()\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.temperature-container {\n  padding: 20px;\n}\n</style>\n"],"mappings":"AAsDA,YAAAA,OAAA;AACA,SAAAC,OAAA,EAAAC,QAAA,EAAAC,SAAA,EAAAC,SAAA;AACA,SAAAH,OAAA,IAAAI,YAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;MACAC,MAAA;MACAC,MAAA;MACAC,aAAA;MACAC,KAAA;MACAC,UAAA;QACAC,OAAA;QACAC,IAAA;QACAC,KAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,QAAA;IACA,KAAAC,UAAA;IACA,KAAAC,UAAA;EACA;EACAC,cAAA;IACA,SAAAT,KAAA;MACA,KAAAA,KAAA,CAAAU,OAAA;IACA;EACA;EACAC,OAAA;IACAL,SAAA;MACA,MAAAM,MAAA;QACAV,OAAA,OAAAD,UAAA,CAAAC,OAAA;QACAC,IAAA,OAAAF,UAAA,CAAAE;MACA;MACAd,OAAA,CAAAuB,MAAA,EAAAC,IAAA,CAAAC,QAAA;QACA,KAAAlB,SAAA,GAAAkB,QAAA,CAAAnB,IAAA,CAAAoB,OAAA;QACA,KAAAd,UAAA,CAAAG,KAAA,GAAAU,QAAA,CAAAnB,IAAA,CAAAS,KAAA;MACA;IACA;IACAG,WAAA;MACAd,YAAA;QAAAS,OAAA;QAAAC,IAAA;MAAA,GAAAU,IAAA,CAAAC,QAAA;QACA,KAAAhB,MAAA,GAAAgB,QAAA,CAAAnB,IAAA,CAAAoB,OAAA;MACA;IACA;IACAP,WAAA;MACAjB,SAAA,GAAAsB,IAAA,CAAAC,QAAA;QACA,KAAAjB,MAAA,GAAAiB,QAAA,CAAAnB,IAAA;MACA;IACA;IACAqB,UAAAC,OAAA;MACA,KAAAA,OAAA;MAEA3B,QAAA,CAAA2B,OAAA,EAAAJ,IAAA,CAAAC,QAAA;QACA,MAAAnB,IAAA,GAAAmB,QAAA,CAAAnB,IAAA;QACA,KAAAuB,SAAA,CAAAvB,IAAA,CAAAwB,KAAA,EAAAxB,IAAA,CAAAyB,YAAA,EAAAzB,IAAA,CAAA0B,UAAA;MACA;IACA;IACAH,UAAAC,KAAA,EAAAC,YAAA,EAAAC,UAAA;MACA,UAAAC,KAAA,CAAAtB,KAAA;MAEA,KAAAA,KAAA,GAAAZ,OAAA,CAAAmC,IAAA,MAAAD,KAAA,CAAAtB,KAAA;MACA,MAAAwB,MAAA;QACAC,OAAA;UACAC,OAAA;QACA;QACAC,MAAA;UACAhC,IAAA;QACA;QACAiC,KAAA;UACAC,IAAA;UACAlC,IAAA,EAAAwB;QACA;QACAW,KAAA,GACA;UACAD,IAAA;UACAnC,IAAA;UACAqC,SAAA;YACAC,SAAA;UACA;QACA,GACA;