{"ast":null,"code":"import { logout } from '@/api/portal/auth';\nexport default {\n  name: 'Layout',\n  computed: {\n    username() {\n      return this.$store.state.userInfo?.username || '用户';\n    },\n    activeMenu() {\n      const route = this.$route;\n      return route.path;\n    }\n  },\n  methods: {\n    handleCommand(command) {\n      if (command === 'logout') {\n        logout().then(() => {\n          this.$store.dispatch('logout');\n          this.$router.push('/login');\n        });\n      } else if (command === 'profile') {\n        this.$router.push('/user/profile');\n      }\n    }\n  }\n};","map":{"version":3,"names":["logout","name","computed","username","$store","state","userInfo","activeMenu","route","$route","path","methods","handleCommand","command","then","dispatch","$router","push"],"sources":["src/layout/index.vue"],"sourcesContent":["<template>\n  <div class=\"app-wrapper\">\n    <div class=\"navbar\">\n      <div class=\"navbar-content\">\n        <div class=\"logo\">\n          <router-link to=\"/home\">智慧冷链物流</router-link>\n        </div>\n        <el-menu\n          :default-active=\"activeMenu\"\n          mode=\"horizontal\"\n          router\n          class=\"navbar-menu\"\n        >\n          <el-menu-item index=\"/home\">首页</el-menu-item>\n          <el-menu-item index=\"/order/create\">下单寄件</el-menu-item>\n          <el-menu-item index=\"/order/list\">我的订单</el-menu-item>\n          <el-menu-item index=\"/track/index\">运单追踪</el-menu-item>\n        </el-menu>\n        <div class=\"user-info\">\n          <el-dropdown @command=\"handleCommand\">\n            <span class=\"el-dropdown-link\">\n              {{ username }}<i class=\"el-icon-arrow-down el-icon--right\"></i>\n            </span>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item command=\"profile\">个人信息</el-dropdown-item>\n              <el-dropdown-item command=\"logout\">退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"main-container\">\n      <router-view />\n    </div>\n  </div>\n</template>\n\n<script>\nimport { logout } from '@/api/portal/auth'\n\nexport default {\n  name: 'Layout',\n  computed: {\n    username() {\n      return this.$store.state.userInfo?.username || '用户'\n    },\n    activeMenu() {\n      const route = this.$route\n      return route.path\n    }\n  },\n  methods: {\n    handleCommand(command) {\n      if (command === 'logout') {\n        logout().then(() => {\n          this.$store.dispatch('logout')\n          this.$router.push('/login')\n        })\n      } else if (command === 'profile') {\n        this.$router.push('/user/profile')\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.app-wrapper {\n  min-height: 100vh;\n\n  .navbar {\n    background: white;\n    box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\n    position: sticky;\n    top: 0;\n    z-index: 1000;\n\n    .navbar-content {\n      max-width: 1200px;\n      margin: 0 auto;\n      display: flex;\n      align-items: center;\n      padding: 0 20px;\n      height: 60px;\n\n      .logo {\n        font-size: 20px;\n        font-weight: bold;\n        margin-right: 50px;\n\n        a {\n          color: #333;\n          text-decoration: none;\n        }\n      }\n\n      .navbar-menu {\n        flex: 1;\n        border-bottom: none;\n      }\n\n      .user-info {\n        margin-left: auto;\n\n        .el-dropdown-link {\n          cursor: pointer;\n          color: #333;\n        }\n      }\n    }\n  }\n\n  .main-container {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 20px;\n  }\n}\n</style>\n"],"mappings":"AAuCA,SAAAA,MAAA;AAEA;EACAC,IAAA;EACAC,QAAA;IACAC,SAAA;MACA,YAAAC,MAAA,CAAAC,KAAA,CAAAC,QAAA,EAAAH,QAAA;IACA;IACAI,WAAA;MACA,MAAAC,KAAA,QAAAC,MAAA;MACA,OAAAD,KAAA,CAAAE,IAAA;IACA;EACA;EACAC,OAAA;IACAC,cAAAC,OAAA;MACA,IAAAA,OAAA;QACAb,MAAA,GAAAc,IAAA;UACA,KAAAV,MAAA,CAAAW,QAAA;UACA,KAAAC,OAAA,CAAAC,IAAA;QACA;MACA,WAAAJ,OAAA;QACA,KAAAG,OAAA,CAAAC,IAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}