{"ast":null,"code":"import { getList, cancel } from '@/api/portal/order';\nexport default {\n  name: 'OrderList',\n  data() {\n    return {\n      activeTab: '',\n      tableData: [],\n      pagination: {\n        current: 1,\n        size: 10,\n        total: 0\n      }\n    };\n  },\n  mounted() {\n    this.loadData();\n  },\n  methods: {\n    loadData() {\n      const userId = this.$store.state.userInfo?.userId;\n      if (!userId) {\n        this.$message.error('请先登录');\n        this.$router.push('/login');\n        return;\n      }\n      const params = {\n        userId,\n        current: this.pagination.current,\n        size: this.pagination.size,\n        orderStatus: this.activeTab !== '' ? parseInt(this.activeTab) : null\n      };\n      getList(params).then(response => {\n        this.tableData = response.data.records;\n        this.pagination.total = response.data.total;\n      });\n    },\n    handleTabClick() {\n      this.pagination.current = 1;\n      this.loadData();\n    },\n    handlePageChange(page) {\n      this.pagination.current = page;\n      this.loadData();\n    },\n    handleTrack(order) {\n      this.$router.push({\n        path: '/track/index',\n        query: {\n          orderNo: order.orderNo\n        }\n      });\n    },\n    handleCancel(order) {\n      this.$confirm('确认取消该订单吗？', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        cancel(order.orderNo).then(() => {\n          this.$message.success('订单已取消');\n          this.loadData();\n        });\n      });\n    },\n    getStatusText(status) {\n      const map = {\n        0: '待取件',\n        1: '运输中',\n        2: '派送中',\n        3: '已签收',\n        4: '已取消'\n      };\n      return map[status] || '未知';\n    },\n    getStatusType(status) {\n      const map = {\n        0: 'warning',\n        1: 'primary',\n        2: 'info',\n        3: 'success',\n        4: 'danger'\n      };\n      return map[status] || 'info';\n    }\n  }\n};","map":{"version":3,"names":["getList","cancel","name","data","activeTab","tableData","pagination","current","size","total","mounted","loadData","methods","userId","$store","state","userInfo","$message","error","$router","push","params","orderStatus","parseInt","then","response","records","handleTabClick","handlePageChange","page","handleTrack","order","path","query","orderNo","handleCancel","$confirm","confirmButtonText","cancelButtonText","type","success","getStatusText","status","map","getStatusType"],"sources":["src/views/order/list.vue"],"sourcesContent":["<template>\n  <div class=\"order-list-container\">\n    <el-card>\n      <div slot=\"header\">\n        <span>我的订单</span>\n      </div>\n\n      <el-tabs v-model=\"activeTab\" @tab-click=\"handleTabClick\">\n        <el-tab-pane label=\"全部\" name=\"\"></el-tab-pane>\n        <el-tab-pane label=\"待取件\" name=\"0\"></el-tab-pane>\n        <el-tab-pane label=\"运输中\" name=\"1\"></el-tab-pane>\n        <el-tab-pane label=\"派送中\" name=\"2\"></el-tab-pane>\n        <el-tab-pane label=\"已完成\" name=\"3\"></el-tab-pane>\n        <el-tab-pane label=\"已取消\" name=\"4\"></el-tab-pane>\n      </el-tabs>\n\n      <div v-if=\"tableData.length === 0\" class=\"empty-state\">\n        <p>暂无订单</p>\n        <el-button type=\"primary\" @click=\"$router.push('/order/create')\">立即下单</el-button>\n      </div>\n\n      <div v-else class=\"order-list\">\n        <el-card v-for=\"order in tableData\" :key=\"order.id\" class=\"order-card\">\n          <div class=\"order-header\">\n            <span class=\"order-no\">订单号：{{ order.orderNo }}</span>\n            <el-tag :type=\"getStatusType(order.orderStatus)\">{{ getStatusText(order.orderStatus) }}</el-tag>\n          </div>\n          <div class=\"order-body\">\n            <div class=\"order-info\">\n              <div class=\"info-item\">\n                <label>寄件人：</label>\n                <span>{{ order.senderName }} {{ order.senderPhone }}</span>\n              </div>\n              <div class=\"info-item\">\n                <label>收件人：</label>\n                <span>{{ order.receiverName }} {{ order.receiverPhone }}</span>\n              </div>\n              <div class=\"info-item\">\n                <label>货物：</label>\n                <span>{{ order.goodsName }} ({{ order.goodsWeight }}kg)</span>\n              </div>\n              <div class=\"info-item\">\n                <label>温度要求：</label>\n                <span>{{ order.temperatureRequirement }}</span>\n              </div>\n            </div>\n            <div class=\"order-actions\">\n              <el-button size=\"mini\" type=\"primary\" @click=\"handleTrack(order)\">追踪</el-button>\n              <el-button v-if=\"order.orderStatus === 0\" size=\"mini\" type=\"danger\" @click=\"handleCancel(order)\">\n                取消订单\n              </el-button>\n            </div>\n          </div>\n          <div class=\"order-footer\">\n            <span>下单时间：{{ order.createTime }}</span>\n          </div>\n        </el-card>\n      </div>\n\n      <el-pagination\n        v-if=\"pagination.total > 0\"\n        @current-change=\"handlePageChange\"\n        :current-page=\"pagination.current\"\n        :page-size=\"pagination.size\"\n        :total=\"pagination.total\"\n        layout=\"total, prev, pager, next\"\n        style=\"margin-top: 20px; text-align: right;\">\n      </el-pagination>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport { getList, cancel } from '@/api/portal/order'\n\nexport default {\n  name: 'OrderList',\n  data() {\n    return {\n      activeTab: '',\n      tableData: [],\n      pagination: {\n        current: 1,\n        size: 10,\n        total: 0\n      }\n    }\n  },\n  mounted() {\n    this.loadData()\n  },\n  methods: {\n    loadData() {\n      const userId = this.$store.state.userInfo?.userId\n      if (!userId) {\n        this.$message.error('请先登录')\n        this.$router.push('/login')\n        return\n      }\n\n      const params = {\n        userId,\n        current: this.pagination.current,\n        size: this.pagination.size,\n        orderStatus: this.activeTab !== '' ? parseInt(this.activeTab) : null\n      }\n\n      getList(params).then(response => {\n        this.tableData = response.data.records\n        this.pagination.total = response.data.total\n      })\n    },\n    handleTabClick() {\n      this.pagination.current = 1\n      this.loadData()\n    },\n    handlePageChange(page) {\n      this.pagination.current = page\n      this.loadData()\n    },\n    handleTrack(order) {\n      this.$router.push({ path: '/track/index', query: { orderNo: order.orderNo } })\n    },\n    handleCancel(order) {\n      this.$confirm('确认取消该订单吗？', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        cancel(order.orderNo).then(() => {\n          this.$message.success('订单已取消')\n          this.loadData()\n        })\n      })\n    },\n    getStatusText(status) {\n      const map = {\n        0: '待取件',\n        1: '运输中',\n        2: '派送中',\n        3: '已签收',\n        4: '已取消'\n      }\n      return map[status] || '未知'\n    },\n    getStatusType(status) {\n      const map = {\n        0: 'warning',\n        1: 'primary',\n        2: 'info',\n        3: 'success',\n        4: 'danger'\n      }\n      return map[status] || 'info'\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.order-list-container {\n  .empty-state {\n    text-align: center;\n    padding: 60px 0;\n\n    p {\n      color: #999;\n      margin-bottom: 20px;\n    }\n  }\n\n  .order-list {\n    .order-card {\n      margin-bottom: 15px;\n\n      .order-header {\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        margin-bottom: 15px;\n\n        .order-no {\n          font-weight: bold;\n          color: #333;\n        }\n      }\n\n      .order-body {\n        display: flex;\n        justify-content: space-between;\n\n        .order-info {\n          flex: 1;\n\n          .info-item {\n            margin-bottom: 8px;\n\n            label {\n              color: #999;\n              margin-right: 10px;\n            }\n          }\n        }\n\n        .order-actions {\n          display: flex;\n          flex-direction: column;\n          gap: 10px;\n        }\n      }\n\n      .order-footer {\n        margin-top: 15px;\n        padding-top: 15px;\n        border-top: 1px solid #eee;\n        font-size: 12px;\n        color: #999;\n      }\n    }\n  }\n}\n</style>\n"],"mappings":"AAyEA,SAAAA,OAAA,EAAAC,MAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;MACAC,SAAA;MACAC,UAAA;QACAC,OAAA;QACAC,IAAA;QACAC,KAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACAD,SAAA;MACA,MAAAE,MAAA,QAAAC,MAAA,CAAAC,KAAA,CAAAC,QAAA,EAAAH,MAAA;MACA,KAAAA,MAAA;QACA,KAAAI,QAAA,CAAAC,KAAA;QACA,KAAAC,OAAA,CAAAC,IAAA;QACA;MACA;MAEA,MAAAC,MAAA;QACAR,MAAA;QACAN,OAAA,OAAAD,UAAA,CAAAC,OAAA;QACAC,IAAA,OAAAF,UAAA,CAAAE,IAAA;QACAc,WAAA,OAAAlB,SAAA,UAAAmB,QAAA,MAAAnB,SAAA;MACA;MAEAJ,OAAA,CAAAqB,MAAA,EAAAG,IAAA,CAAAC,QAAA;QACA,KAAApB,SAAA,GAAAoB,QAAA,CAAAtB,IAAA,CAAAuB,OAAA;QACA,KAAApB,UAAA,CAAAG,KAAA,GAAAgB,QAAA,CAAAtB,IAAA,CAAAM,KAAA;MACA;IACA;IACAkB,eAAA;MACA,KAAArB,UAAA,CAAAC,OAAA;MACA,KAAAI,QAAA;IACA;IACAiB,iBAAAC,IAAA;MACA,KAAAvB,UAAA,CAAAC,OAAA,GAAAsB,IAAA;MACA,KAAAlB,QAAA;IACA;IACAmB,YAAAC,KAAA;MACA,KAAAZ,OAAA,CAAAC,IAAA;QAAAY,IAAA;QAAAC,KAAA;UAAAC,OAAA,EAAAH,KAAA,CAAAG;QAAA;MAAA;IACA;IACAC,aAAAJ,KAAA;MACA,KAAAK,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GAAAf,IAAA;QACAvB,MAAA,CAAA8B,KAAA,CAAAG,OAAA,EAAAV,IAAA;UACA,KAAAP,QAAA,CAAAuB,OAAA;UACA,KAAA7B,QAAA;QACA;MACA;IACA;IACA8B,cAAAC,MAAA;MACA,MAAAC,GAAA;QACA;QACA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAD,MAAA;IACA;IACAE,cAAAF,MAAA;MACA,MAAAC,GAAA;QACA;QACA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAD,MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}