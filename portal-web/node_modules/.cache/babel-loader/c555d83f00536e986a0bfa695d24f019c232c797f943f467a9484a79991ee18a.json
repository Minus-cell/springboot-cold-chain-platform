{"ast":null,"code":"import { create } from '@/api/portal/order';\nexport default {\n  name: 'CreateOrder',\n  data() {\n    return {\n      currentStep: 0,\n      loading: false,\n      form: {\n        senderName: '',\n        senderPhone: '',\n        senderAddress: '',\n        receiverName: '',\n        receiverPhone: '',\n        receiverAddress: '',\n        goodsName: '',\n        goodsWeight: null,\n        goodsVolume: null,\n        temperatureRequirement: ''\n      },\n      rules: {\n        senderName: [{\n          required: true,\n          message: '请输入寄件人姓名',\n          trigger: 'blur'\n        }],\n        senderPhone: [{\n          required: true,\n          message: '请输入寄件人电话',\n          trigger: 'blur'\n        }],\n        senderAddress: [{\n          required: true,\n          message: '请输入寄件人地址',\n          trigger: 'blur'\n        }],\n        receiverName: [{\n          required: true,\n          message: '请输入收件人姓名',\n          trigger: 'blur'\n        }],\n        receiverPhone: [{\n          required: true,\n          message: '请输入收件人电话',\n          trigger: 'blur'\n        }],\n        receiverAddress: [{\n          required: true,\n          message: '请输入收件人地址',\n          trigger: 'blur'\n        }],\n        goodsName: [{\n          required: true,\n          message: '请输入货物名称',\n          trigger: 'blur'\n        }],\n        temperatureRequirement: [{\n          required: true,\n          message: '请选择温度要求',\n          trigger: 'change'\n        }],\n        goodsWeight: [{\n          required: true,\n          message: '请输入货物重量',\n          trigger: 'blur'\n        }],\n        goodsVolume: [{\n          required: true,\n          message: '请输入货物体积',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  methods: {\n    nextStep() {\n      let validFields = [];\n      if (this.currentStep === 0) {\n        validFields = ['senderName', 'senderPhone', 'senderAddress'];\n      } else if (this.currentStep === 1) {\n        validFields = ['receiverName', 'receiverPhone', 'receiverAddress'];\n      } else if (this.currentStep === 2) {\n        validFields = ['goodsName', 'temperatureRequirement', 'goodsWeight', 'goodsVolume'];\n      }\n      this.$refs.form.validateField(validFields, error => {\n        if (!error) {\n          this.currentStep++;\n        }\n      });\n    },\n    prevStep() {\n      this.currentStep--;\n    },\n    handleSubmit() {\n      this.loading = true;\n      this.form.userId = this.$store.state.userInfo?.userId;\n      create(this.form).then(() => {\n        this.$message.success('订单提交成功！');\n        this.$router.push('/order/list');\n      }).catch(() => {\n        this.loading = false;\n      });\n    }\n  }\n};","map":{"version":3,"names":["create","name","data","currentStep","loading","form","senderName","senderPhone","senderAddress","receiverName","receiverPhone","receiverAddress","goodsName","goodsWeight","goodsVolume","temperatureRequirement","rules","required","message","trigger","methods","nextStep","validFields","$refs","validateField","error","prevStep","handleSubmit","userId","$store","state","userInfo","then","$message","success","$router","push","catch"],"sources":["src/views/order/create.vue"],"sourcesContent":["<template>\n  <div class=\"create-order-container\">\n    <el-card>\n      <div slot=\"header\">\n        <span>下单寄件</span>\n      </div>\n\n      <el-steps :active=\"currentStep\" finish-status=\"success\" style=\"margin-bottom: 30px;\">\n        <el-step title=\"填写寄件信息\"></el-step>\n        <el-step title=\"填写收件信息\"></el-step>\n        <el-step title=\"填写货物信息\"></el-step>\n        <el-step title=\"确认提交\"></el-step>\n      </el-steps>\n\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"form\" label-width=\"120px\">\n        <div v-show=\"currentStep === 0\">\n          <el-form-item label=\"寄件人姓名\" prop=\"senderName\">\n            <el-input v-model=\"form.senderName\" placeholder=\"请输入寄件人姓名\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"寄件人电话\" prop=\"senderPhone\">\n            <el-input v-model=\"form.senderPhone\" placeholder=\"请输入寄件人电话\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"寄件人地址\" prop=\"senderAddress\">\n            <el-input v-model=\"form.senderAddress\" placeholder=\"请输入寄件人详细地址\"></el-input>\n          </el-form-item>\n        </div>\n\n        <div v-show=\"currentStep === 1\">\n          <el-form-item label=\"收件人姓名\" prop=\"receiverName\">\n            <el-input v-model=\"form.receiverName\" placeholder=\"请输入收件人姓名\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"收件人电话\" prop=\"receiverPhone\">\n            <el-input v-model=\"form.receiverPhone\" placeholder=\"请输入收件人电话\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"收件人地址\" prop=\"receiverAddress\">\n            <el-input v-model=\"form.receiverAddress\" placeholder=\"请输入收件人详细地址\"></el-input>\n          </el-form-item>\n        </div>\n\n        <div v-show=\"currentStep === 2\">\n          <el-form-item label=\"货物名称\" prop=\"goodsName\">\n            <el-input v-model=\"form.goodsName\" placeholder=\"请输入货物名称\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"温度要求\" prop=\"temperatureRequirement\">\n            <el-select v-model=\"form.temperatureRequirement\" placeholder=\"请选择温度要求\" style=\"width: 100%;\">\n              <el-option label=\"-18℃以下（冷冻）\" value=\"-18℃以下\"></el-option>\n              <el-option label=\"0~5℃（冷藏）\" value=\"0~5℃\"></el-option>\n              <el-option label=\"2~8℃（冷藏）\" value=\"2~8℃\"></el-option>\n              <el-option label=\"常温\" value=\"常温\"></el-option>\n            </el-select>\n          </el-form-item>\n          <el-row :gutter=\"20\">\n            <el-col :span=\"12\">\n              <el-form-item label=\"重量(kg)\" prop=\"goodsWeight\">\n                <el-input-number v-model=\"form.goodsWeight\" :min=\"0\" :precision=\"2\" style=\"width: 100%;\"></el-input-number>\n              </el-form-item>\n            </el-col>\n            <el-col :span=\"12\">\n              <el-form-item label=\"体积(m³)\" prop=\"goodsVolume\">\n                <el-input-number v-model=\"form.goodsVolume\" :min=\"0\" :precision=\"2\" style=\"width: 100%;\"></el-input-number>\n              </el-form-item>\n            </el-col>\n          </el-row>\n        </div>\n\n        <div v-show=\"currentStep === 3\">\n          <el-card class=\"summary-card\">\n            <div slot=\"header\">\n              <span>订单信息确认</span>\n            </div>\n            <el-descriptions :column=\"2\" border>\n              <el-descriptions-item label=\"寄件人\">{{ form.senderName }}</el-descriptions-item>\n              <el-descriptions-item label=\"寄件人电话\">{{ form.senderPhone }}</el-descriptions-item>\n              <el-descriptions-item label=\"寄件人地址\" :span=\"2\">{{ form.senderAddress }}</el-descriptions-item>\n              <el-descriptions-item label=\"收件人\">{{ form.receiverName }}</el-descriptions-item>\n              <el-descriptions-item label=\"收件人电话\">{{ form.receiverPhone }}</el-descriptions-item>\n              <el-descriptions-item label=\"收件人地址\" :span=\"2\">{{ form.receiverAddress }}</el-descriptions-item>\n              <el-descriptions-item label=\"货物名称\">{{ form.goodsName }}</el-descriptions-item>\n              <el-descriptions-item label=\"温度要求\">{{ form.temperatureRequirement }}</el-descriptions-item>\n              <el-descriptions-item label=\"重量\">{{ form.goodsWeight }} kg</el-descriptions-item>\n              <el-descriptions-item label=\"体积\">{{ form.goodsVolume }} m³</el-descriptions-item>\n            </el-descriptions>\n          </el-card>\n        </div>\n\n        <el-form-item style=\"margin-top: 30px;\">\n          <el-button v-if=\"currentStep > 0\" @click=\"prevStep\">上一步</el-button>\n          <el-button v-if=\"currentStep < 3\" type=\"primary\" @click=\"nextStep\">下一步</el-button>\n          <el-button v-if=\"currentStep === 3\" type=\"primary\" @click=\"handleSubmit\" :loading=\"loading\">\n            提交订单\n          </el-button>\n        </el-form-item>\n      </el-form>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport { create } from '@/api/portal/order'\n\nexport default {\n  name: 'CreateOrder',\n  data() {\n    return {\n      currentStep: 0,\n      loading: false,\n      form: {\n        senderName: '',\n        senderPhone: '',\n        senderAddress: '',\n        receiverName: '',\n        receiverPhone: '',\n        receiverAddress: '',\n        goodsName: '',\n        goodsWeight: null,\n        goodsVolume: null,\n        temperatureRequirement: ''\n      },\n      rules: {\n        senderName: [{ required: true, message: '请输入寄件人姓名', trigger: 'blur' }],\n        senderPhone: [{ required: true, message: '请输入寄件人电话', trigger: 'blur' }],\n        senderAddress: [{ required: true, message: '请输入寄件人地址', trigger: 'blur' }],\n        receiverName: [{ required: true, message: '请输入收件人姓名', trigger: 'blur' }],\n        receiverPhone: [{ required: true, message: '请输入收件人电话', trigger: 'blur' }],\n        receiverAddress: [{ required: true, message: '请输入收件人地址', trigger: 'blur' }],\n        goodsName: [{ required: true, message: '请输入货物名称', trigger: 'blur' }],\n        temperatureRequirement: [{ required: true, message: '请选择温度要求', trigger: 'change' }],\n        goodsWeight: [{ required: true, message: '请输入货物重量', trigger: 'blur' }],\n        goodsVolume: [{ required: true, message: '请输入货物体积', trigger: 'blur' }]\n      }\n    }\n  },\n  methods: {\n    nextStep() {\n      let validFields = []\n      if (this.currentStep === 0) {\n        validFields = ['senderName', 'senderPhone', 'senderAddress']\n      } else if (this.currentStep === 1) {\n        validFields = ['receiverName', 'receiverPhone', 'receiverAddress']\n      } else if (this.currentStep === 2) {\n        validFields = ['goodsName', 'temperatureRequirement', 'goodsWeight', 'goodsVolume']\n      }\n\n      this.$refs.form.validateField(validFields, (error) => {\n        if (!error) {\n          this.currentStep++\n        }\n      })\n    },\n    prevStep() {\n      this.currentStep--\n    },\n    handleSubmit() {\n      this.loading = true\n      this.form.userId = this.$store.state.userInfo?.userId\n\n      create(this.form).then(() => {\n        this.$message.success('订单提交成功！')\n        this.$router.push('/order/list')\n      }).catch(() => {\n        this.loading = false\n      })\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.create-order-container {\n  max-width: 800px;\n  margin: 0 auto;\n\n  .summary-card {\n    margin-bottom: 20px;\n  }\n}\n</style>\n"],"mappings":"AAkGA,SAAAA,MAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,WAAA;MACAC,OAAA;MACAC,IAAA;QACAC,UAAA;QACAC,WAAA;QACAC,aAAA;QACAC,YAAA;QACAC,aAAA;QACAC,eAAA;QACAC,SAAA;QACAC,WAAA;QACAC,WAAA;QACAC,sBAAA;MACA;MACAC,KAAA;QACAV,UAAA;UAAAW,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAZ,WAAA;UAAAU,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAX,aAAA;UAAAS,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAV,YAAA;UAAAQ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAT,aAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAR,eAAA;UAAAM,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAP,SAAA;UAAAK,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAJ,sBAAA;UAAAE,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAN,WAAA;UAAAI,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAL,WAAA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAC,OAAA;IACAC,SAAA;MACA,IAAAC,WAAA;MACA,SAAAnB,WAAA;QACAmB,WAAA;MACA,gBAAAnB,WAAA;QACAmB,WAAA;MACA,gBAAAnB,WAAA;QACAmB,WAAA;MACA;MAEA,KAAAC,KAAA,CAAAlB,IAAA,CAAAmB,aAAA,CAAAF,WAAA,EAAAG,KAAA;QACA,KAAAA,KAAA;UACA,KAAAtB,WAAA;QACA;MACA;IACA;IACAuB,SAAA;MACA,KAAAvB,WAAA;IACA;IACAwB,aAAA;MACA,KAAAvB,OAAA;MACA,KAAAC,IAAA,CAAAuB,MAAA,QAAAC,MAAA,CAAAC,KAAA,CAAAC,QAAA,EAAAH,MAAA;MAEA5B,MAAA,MAAAK,IAAA,EAAA2B,IAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;QACA,KAAAC,OAAA,CAAAC,IAAA;MACA,GAAAC,KAAA;QACA,KAAAjC,OAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}