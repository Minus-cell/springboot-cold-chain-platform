{"ast":null,"code":"import * as echarts from 'echarts';\nimport { track } from '@/api/portal/track';\nimport { getTemperature } from '@/api/portal/track';\nexport default {\n  name: 'Track',\n  data() {\n    return {\n      orderNo: '',\n      hasSearched: false,\n      orderData: null,\n      temperatureData: []\n    };\n  },\n  mounted() {\n    const queryOrderNo = this.$route.query.orderNo;\n    if (queryOrderNo) {\n      this.orderNo = queryOrderNo;\n      this.handleTrack();\n    }\n  },\n  beforeDestroy() {\n    if (this.tempChart) {\n      this.tempChart.dispose();\n    }\n  },\n  methods: {\n    handleTrack() {\n      if (!this.orderNo) {\n        this.$message.warning('请输入订单号');\n        return;\n      }\n      this.hasSearched = true;\n      track(this.orderNo).then(response => {\n        this.orderData = response.data;\n        this.loadTemperature();\n      }).catch(() => {\n        this.orderData = null;\n      });\n    },\n    loadTemperature() {\n      getTemperature(this.orderNo).then(response => {\n        this.temperatureData = response.data;\n        this.$nextTick(() => {\n          this.initTempChart();\n        });\n      });\n    },\n    initTempChart() {\n      if (!this.$refs.tempChart || this.temperatureData.length === 0) return;\n      this.tempChart = echarts.init(this.$refs.tempChart);\n      const option = {\n        tooltip: {\n          trigger: 'axis'\n        },\n        xAxis: {\n          type: 'category',\n          data: this.temperatureData.map(item => item.recordTime)\n        },\n        yAxis: {\n          type: 'value',\n          name: '温度(℃)'\n        },\n        series: [{\n          data: this.temperatureData.map(item => item.temperature),\n          type: 'line',\n          smooth: true,\n          areaStyle: {\n            color: 'rgba(64, 158, 255, 0.2)'\n          }\n        }]\n      };\n      this.tempChart.setOption(option);\n    },\n    getStatusText(status) {\n      const map = {\n        0: '待取件',\n        1: '运输中',\n        2: '派送中',\n        3: '已签收',\n        4: '已取消'\n      };\n      return map[status] || '未知';\n    },\n    getStatusType(status) {\n      const map = {\n        0: 'warning',\n        1: 'primary',\n        2: 'info',\n        3: 'success',\n        4: 'danger'\n      };\n      return map[status] || 'info';\n    }\n  }\n};","map":{"version":3,"names":["echarts","track","getTemperature","name","data","orderNo","hasSearched","orderData","temperatureData","mounted","queryOrderNo","$route","query","handleTrack","beforeDestroy","tempChart","dispose","methods","$message","warning","then","response","loadTemperature","catch","$nextTick","initTempChart","$refs","length","init","option","tooltip","trigger","xAxis","type","map","item","recordTime","yAxis","series","temperature","smooth","areaStyle","color","setOption","getStatusText","status","getStatusType"],"sources":["src/views/track/index.vue"],"sourcesContent":["<template>\n  <div class=\"track-container\">\n    <el-card>\n      <div slot=\"header\">\n        <span>运单追踪</span>\n      </div>\n\n      <el-form :inline=\"true\">\n        <el-form-item label=\"订单号\">\n          <el-input v-model=\"orderNo\" placeholder=\"请输入订单号\" style=\"width: 300px;\"></el-input>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"handleTrack\">追踪</el-button>\n        </el-form-item>\n      </el-form>\n\n      <div v-if=\"orderData\" class=\"track-result\">\n        <el-card class=\"order-info-card\">\n          <el-descriptions :column=\"2\" border>\n            <el-descriptions-item label=\"订单号\">{{ orderData.order.orderNo }}</el-descriptions-item>\n            <el-descriptions-item label=\"状态\">\n              <el-tag :type=\"getStatusType(orderData.order.orderStatus)\">\n                {{ getStatusText(orderData.order.orderStatus) }}\n              </el-tag>\n            </el-descriptions-item>\n            <el-descriptions-item label=\"寄件人\">{{ orderData.order.senderName }}</el-descriptions-item>\n            <el-descriptions-item label=\"寄件人电话\">{{ orderData.order.senderPhone }}</el-descriptions-item>\n            <el-descriptions-item label=\"寄件人地址\" :span=\"2\">{{ orderData.order.senderAddress }}</el-descriptions-item>\n            <el-descriptions-item label=\"收件人\">{{ orderData.order.receiverName }}</el-descriptions-item>\n            <el-descriptions-item label=\"收件人电话\">{{ orderData.order.receiverPhone }}</el-descriptions-item>\n            <el-descriptions-item label=\"收件人地址\" :span=\"2\">{{ orderData.order.receiverAddress }}</el-descriptions-item>\n            <el-descriptions-item label=\"货物名称\">{{ orderData.order.goodsName }}</el-descriptions-item>\n            <el-descriptions-item label=\"温度要求\">{{ orderData.order.temperatureRequirement }}</el-descriptions-item>\n          </el-descriptions>\n        </el-card>\n\n        <el-card class=\"timeline-card\" style=\"margin-top: 20px;\">\n          <div slot=\"header\">\n            <span>物流轨迹</span>\n          </div>\n          <el-timeline>\n            <el-timeline-item\n              v-for=\"(item, index) in orderData.timeline\"\n              :key=\"index\"\n              :timestamp=\"item.time\"\n              placement=\"top\"\n              :type=\"index === 0 ? 'primary' : 'success'\"\n            >\n              <el-card>\n                <h4>{{ item.status }}</h4>\n                <p>{{ item.description }}</p>\n              </el-card>\n            </el-timeline-item>\n          </el-timeline>\n        </el-card>\n\n        <el-card v-if=\"temperatureData.length > 0\" class=\"temperature-card\" style=\"margin-top: 20px;\">\n          <div slot=\"header\">\n            <span>温度监控</span>\n          </div>\n          <div ref=\"tempChart\" style=\"height: 300px;\"></div>\n        </el-card>\n      </div>\n\n      <div v-else-if=\"hasSearched\" class=\"empty-result\">\n        <p>未找到相关订单</p>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nimport { track } from '@/api/portal/track'\nimport { getTemperature } from '@/api/portal/track'\n\nexport default {\n  name: 'Track',\n  data() {\n    return {\n      orderNo: '',\n      hasSearched: false,\n      orderData: null,\n      temperatureData: []\n    }\n  },\n  mounted() {\n    const queryOrderNo = this.$route.query.orderNo\n    if (queryOrderNo) {\n      this.orderNo = queryOrderNo\n      this.handleTrack()\n    }\n  },\n  beforeDestroy() {\n    if (this.tempChart) {\n      this.tempChart.dispose()\n    }\n  },\n  methods: {\n    handleTrack() {\n      if (!this.orderNo) {\n        this.$message.warning('请输入订单号')\n        return\n      }\n\n      this.hasSearched = true\n      track(this.orderNo).then(response => {\n        this.orderData = response.data\n        this.loadTemperature()\n      }).catch(() => {\n        this.orderData = null\n      })\n    },\n    loadTemperature() {\n      getTemperature(this.orderNo).then(response => {\n        this.temperatureData = response.data\n        this.$nextTick(() => {\n          this.initTempChart()\n        })\n      })\n    },\n    initTempChart() {\n      if (!this.$refs.tempChart || this.temperatureData.length === 0) return\n\n      this.tempChart = echarts.init(this.$refs.tempChart)\n      const option = {\n        tooltip: {\n          trigger: 'axis'\n        },\n        xAxis: {\n          type: 'category',\n          data: this.temperatureData.map(item => item.recordTime)\n        },\n        yAxis: {\n          type: 'value',\n          name: '温度(℃)'\n        },\n        series: [{\n          data: this.temperatureData.map(item => item.temperature),\n          type: 'line',\n          smooth: true,\n          areaStyle: {\n            color: 'rgba(64, 158, 255, 0.2)'\n          }\n        }]\n      }\n      this.tempChart.setOption(option)\n    },\n    getStatusText(status) {\n      const map = {\n        0: '待取件',\n        1: '运输中',\n        2: '派送中',\n        3: '已签收',\n        4: '已取消'\n      }\n      return map[status] || '未知'\n    },\n    getStatusType(status) {\n      const map = {\n        0: 'warning',\n        1: 'primary',\n        2: 'info',\n        3: 'success',\n        4: 'danger'\n      }\n      return map[status] || 'info'\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.track-container {\n  .empty-result {\n    text-align: center;\n    padding: 60px 0;\n    color: #999;\n  }\n\n  .track-result {\n    margin-top: 20px;\n  }\n}\n</style>\n"],"mappings":"AAwEA,YAAAA,OAAA;AACA,SAAAC,KAAA;AACA,SAAAC,cAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,WAAA;MACAC,SAAA;MACAC,eAAA;IACA;EACA;EACAC,QAAA;IACA,MAAAC,YAAA,QAAAC,MAAA,CAAAC,KAAA,CAAAP,OAAA;IACA,IAAAK,YAAA;MACA,KAAAL,OAAA,GAAAK,YAAA;MACA,KAAAG,WAAA;IACA;EACA;EACAC,cAAA;IACA,SAAAC,SAAA;MACA,KAAAA,SAAA,CAAAC,OAAA;IACA;EACA;EACAC,OAAA;IACAJ,YAAA;MACA,UAAAR,OAAA;QACA,KAAAa,QAAA,CAAAC,OAAA;QACA;MACA;MAEA,KAAAb,WAAA;MACAL,KAAA,MAAAI,OAAA,EAAAe,IAAA,CAAAC,QAAA;QACA,KAAAd,SAAA,GAAAc,QAAA,CAAAjB,IAAA;QACA,KAAAkB,eAAA;MACA,GAAAC,KAAA;QACA,KAAAhB,SAAA;MACA;IACA;IACAe,gBAAA;MACApB,cAAA,MAAAG,OAAA,EAAAe,IAAA,CAAAC,QAAA;QACA,KAAAb,eAAA,GAAAa,QAAA,CAAAjB,IAAA;QACA,KAAAoB,SAAA;UACA,KAAAC,aAAA;QACA;MACA;IACA;IACAA,cAAA;MACA,UAAAC,KAAA,CAAAX,SAAA,SAAAP,eAAA,CAAAmB,MAAA;MAEA,KAAAZ,SAAA,GAAAf,OAAA,CAAA4B,IAAA,MAAAF,KAAA,CAAAX,SAAA;MACA,MAAAc,MAAA;QACAC,OAAA;UACAC,OAAA;QACA;QACAC,KAAA;UACAC,IAAA;UACA7B,IAAA,OAAAI,eAAA,CAAA0B,GAAA,CAAAC,IAAA,IAAAA,IAAA,CAAAC,UAAA;QACA;QACAC,KAAA;UACAJ,IAAA;UACA9B,IAAA;QACA;QACAmC,MAAA;UACAlC,IAAA,OAAAI,eAAA,CAAA0B,GAAA,CAAAC,IAAA,IAAAA,IAAA,CAAAI,WAAA;UACAN,IAAA;UACAO,MAAA;UACAC,SAAA;YACAC,KAAA;UACA;QACA;MACA;MACA,KAAA3B,SAAA,CAAA4B,SAAA,CAAAd,MAAA;IACA;IACAe,cAAAC,MAAA;MACA,MAAAX,GAAA;QACA;QACA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAW,MAAA;IACA;IACAC,cAAAD,MAAA;MACA,MAAAX,GAAA;QACA;QACA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAW,MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}